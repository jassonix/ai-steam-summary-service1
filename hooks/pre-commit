#!/bin/sh
echo "--- проверка перед коммитом ---"

# 1. Запускаем фиксер (автоматически правим стиль)
echo "исправляем стиль кода..."
mvn spring-javaformat:apply

# 2. Добавляем исправленные файлы обратно в индекс (важно!)
git add .

# 3. Запускаем тесты и линтер
echo "запускаем тесты и валидацию..."
mvn clean validate test

if [ $? -ne 0 ]; then
    echo "Тесты не прошли или стиль нарушен. Коммит отменен."
    exit 1
fi

echo "Тесты пройдены. Создаем коммит..."
exit 0